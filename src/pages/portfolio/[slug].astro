---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('portfolio');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;

function getRichText(value: any): string {
  if (!value) return '';
  if (typeof value === 'string') return value;
  if (Array.isArray(value)) {
    return value.map((v) => v.plain_text || '').join('');
  }
  return '';
}

function processBody(body: string): string {
  if (!body) return '';
  // Replace __ASTRO_IMAGE_="{...}" with actual <img> tags
  // The attribute value uses HTML entities: &#x22; = ", &#x2F; = /
  return body.replace(/<img __ASTRO_IMAGE_="([^"]+)"[^>]*>/g, (match, encodedJson) => {
    try {
      // Decode HTML entities
      const jsonStr = encodedJson
        .replace(/&#x22;/g, '"')
        .replace(/&#x2F;/g, '/');
      const data = JSON.parse(jsonStr);
      if (data.src) {
        // "../../assets/images/notion/UUID/filename.png" -> "/images/notion/filename.png"
        const filename = data.src.split('/').pop();
        const publicUrl = `/images/notion/${filename}`;
        return `<img src="${publicUrl}" alt="" class="w-full h-auto rounded-lg" loading="lazy" />`;
      }
    } catch (e) {}
    return match;
  });
}

const title = getRichText(entry.data.properties?.Title?.title);
const rawBody = (entry as any).rendered?.html || entry.body || '';
const body = processBody(rawBody);
const date = entry.data.properties?.Date?.date?.start || undefined;
const tags = (entry.data.properties?.Tags?.multi_select || []).map((t: any) => t.name);
const coverImage = `/images/covers/portfolio-${entry.id}.webp`;
---

<ArticleLayout
  title={title}
  date={date}
  tags={tags}
  backHref="/#portfolio"
>
  <div class="mb-8 rounded-xl overflow-hidden">
    <img src={coverImage} alt={title} class="w-full h-64 object-cover" />
  </div>
  <div set:html={body} />
</ArticleLayout>
